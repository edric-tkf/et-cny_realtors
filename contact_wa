import { useState } from 'react';
import { Button } from '@/components/ui/button';
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
} from '@/components/ui/alert-dialog';
import { MessageCircle } from 'lucide-react';
import { useTextSetting } from '@/lib/editable-settings';

export default function Block() {
  const [showDialog, setShowDialog] = useState(false);
  
  const buttonText = useTextSetting({
    name: 'button-text',
    label: 'Button Text',
    initialValue: 'Chat with us',
  });
  
  const contactName = useTextSetting({
    name: 'contact-name',
    label: 'Contact Name',
    initialValue: 'Christine Chung',
  });
  
  const phoneNumber = useTextSetting({
    name: 'phone-number',
    label: 'Phone Number',
    initialValue: '+6588383836',
  });
  
  const handleWhatsAppRedirect = () => {
    const message = encodeURIComponent('Hi, I would like to get in touch with you.');
    const whatsappUrl = `https://wa.me/${phoneNumber.replace(/[^0-9]/g, '')}?text=${message}`;
    window.open(whatsappUrl, '_blank');
    setShowDialog(false);
  };

  return (
    <>
      <div className="fixed bottom-6 right-6 z-50">
        <Button
          onClick={() => setShowDialog(true)}
          className="bg-[#25D366] hover:bg-[#20BA5A] text-black rounded-full shadow-lg px-6 py-6 flex items-center gap-2"
          size="lg"
        >
          <MessageCircle className="h-6 w-6" />
          <span className="font-medium">{buttonText}</span>
        </Button>
      </div>

      <AlertDialog open={showDialog} onOpenChange={setShowDialog}>
        <AlertDialogContent className="bg-card text-card-foreground">
          <AlertDialogHeader>
            <AlertDialogTitle className="text-foreground">Contact via WhatsApp</AlertDialogTitle>
            <AlertDialogDescription className="text-muted-foreground">
              You will be redirected to WhatsApp to contact {contactName} at {phoneNumber}.
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel className="bg-secondary text-secondary-foreground hover:bg-secondary/80">Cancel</AlertDialogCancel>
            <AlertDialogAction onClick={handleWhatsAppRedirect} className="bg-[#25D366] hover:bg-[#20BA5A] text-black">
              Continue
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </>
  );
}
