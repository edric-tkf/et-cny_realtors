import { useState } from 'react';
import { useRecords, q } from '@/lib/datasource';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { useTextSetting } from '@/lib/editable-settings';
import { MessageCircle } from 'lucide-react';

const select = q.select({
  name: '6wwmX',
  status: 'a5vkW',
  picture: 'fkqhG',
  landSize: '1v36Y',
});

const FOR_SALE_ID = 'b15c1ab6-4adc-46c0-9643-9f96921e83b6';
const SOLD_ID = 'f21d8d41-09ce-4527-9d2a-3bd83a8643c6';

export default function Block() {
  const [activeTab, setActiveTab] = useState('for-sale');
  const [hoveredCard, setHoveredCard] = useState<string | null>(null);
  
  const title = useTextSetting({
    name: 'title',
    label: 'Title',
    initialValue: 'Property Listings',
  });
  
  const subtitle = useTextSetting({
    name: 'subtitle',
    label: 'Subtitle',
    initialValue: 'Browse our current and sold properties',
  });

  const { data: forSaleData, status: forSaleStatus } = useRecords({
    select,
    where: q.array('status').hasAllOf([FOR_SALE_ID]),
    count: 50,
  });

  const { data: soldData, status: soldStatus } = useRecords({
    select,
    where: q.array('status').hasAllOf([SOLD_ID]),
    count: 50,
  });

  const forSaleItems = forSaleData?.pages.flatMap((page) => page.items) || [];
  const soldItems = soldData?.pages.flatMap((page) => page.items) || [];

  const PropertyCard = ({ item, isSold }: { item: any; isSold: boolean }) => {
    const imageUrl = Array.isArray(item.fields.picture)
      ? item.fields.picture[0]?.url
      : item.fields.picture?.url;

    const handleWhatsAppClick = () => {
      const message = encodeURIComponent(`Hi, I'm interested in the property: ${item.fields.name || 'Property Listing'}`);
      window.open(`https://wa.me/6588383836?text=${message}`, '_blank');
    };

    return (
      <Card 
        className={`overflow-hidden transition-all duration-300 hover:shadow-2xl ${
          isSold ? 'opacity-75' : 'hover:scale-[1.02]'
        }`}
        onMouseEnter={() => setHoveredCard(item.id)}
        onMouseLeave={() => setHoveredCard(null)}
      >
        <div className="relative h-64 bg-muted overflow-hidden group">
          {imageUrl ? (
            <>
              <img
                src={imageUrl}
                alt={item.fields.name || 'Property'}
                className="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
            </>
          ) : (
            <div className="w-full h-full flex items-center justify-center text-muted-foreground">
              No image available
            </div>
          )}
          <div className="absolute top-3 right-3 animate-in fade-in slide-in-from-top-2 duration-500">
            <Badge
              variant={isSold ? 'destructive' : 'default'}
              className={`${isSold ? '' : 'bg-primary'} shadow-lg`}
            >
              {isSold ? 'Sold' : 'For Sale'}
            </Badge>
          </div>
          {!isSold && hoveredCard === item.id && (
            <div className="absolute bottom-4 left-4 right-4 animate-in slide-in-from-bottom-4 duration-300">
              <Button
                onClick={handleWhatsAppClick}
                className="w-full bg-green-600 hover:bg-green-700 text-black shadow-lg"
                size="lg"
              >
                <MessageCircle className="mr-2 h-5 w-5" />
                Inquire on WhatsApp
              </Button>
            </div>
          )}
        </div>
        <CardHeader>
          <CardTitle className="text-xl transition-colors duration-300 group-hover:text-primary">{item.fields.name || 'Untitled Property'}</CardTitle>
        </CardHeader>
        <CardContent>
          {item.fields.landSize && (
            <div className="flex items-center gap-2 text-muted-foreground">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                strokeWidth="2"
                strokeLinecap="round"
                strokeLinejoin="round"
              >
                <rect width="18" height="18" x="3" y="3" rx="2" />
              </svg>
              <span>{item.fields.landSize.toLocaleString()} sq ft</span>
            </div>
          )}
        </CardContent>
      </Card>
    );
  };

  return (
    <div className="container py-12">
      <div className="content">
        <div className="text-center mb-12 animate-in fade-in slide-in-from-top-4 duration-700">
          <h1 className="text-4xl font-bold mb-3">{title}</h1>
          <p className="text-lg text-muted-foreground">{subtitle}</p>
        </div>

        <Tabs value={activeTab} onValueChange={setActiveTab} className="w-full">
          <TabsList className="grid w-full max-w-md mx-auto grid-cols-2 mb-8">
            <TabsTrigger value="for-sale" className="transition-all duration-300">
              For Sale ({forSaleItems.length})
            </TabsTrigger>
            <TabsTrigger value="sold" className="transition-all duration-300">
              Sold ({soldItems.length})
            </TabsTrigger>
          </TabsList>

          <TabsContent value="for-sale" className="mt-0 animate-in fade-in slide-in-from-bottom-4 duration-500">
            {forSaleStatus === 'pending' ? (
              <div className="text-center py-12 text-muted-foreground">
                Loading properties...
              </div>
            ) : forSaleStatus === 'error' ? (
              <div className="text-center py-12 text-destructive">
                Error loading properties
              </div>
            ) : forSaleItems.length === 0 ? (
              <div className="text-center py-12 text-muted-foreground">
                No properties for sale at the moment
              </div>
            ) : (
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {forSaleItems.map((item) => (
                  <PropertyCard key={item.id} item={item} isSold={false} />
                ))}
              </div>
            )}
          </TabsContent>

          <TabsContent value="sold" className="mt-0 animate-in fade-in slide-in-from-bottom-4 duration-500">
            {soldStatus === 'pending' ? (
              <div className="text-center py-12 text-muted-foreground">
                Loading properties...
              </div>
            ) : soldStatus === 'error' ? (
              <div className="text-center py-12 text-destructive">
                Error loading properties
              </div>
            ) : soldItems.length === 0 ? (
              <div className="text-center py-12 text-muted-foreground">
                No sold properties to display
              </div>
            ) : (
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {soldItems.map((item) => (
                  <PropertyCard key={item.id} item={item} isSold={true} />
                ))}
              </div>
            )}
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
